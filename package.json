{
  "name": "microsoft-security-news-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "sirv dist --port 4173 --dev",
    "start": "sirv dist --port 4173",
    "fetch": "node scripts/fetch-sources.mjs",
    "normalize": "node scripts/normalize-items.mjs",
    "dataset": "node scripts/build-dataset.mjs",
    "refresh": "npm run fetch && npm run normalize && npm run dataset && npm run build",
    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "sirv-cli": "^3.0.1"
  }
}
